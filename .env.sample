# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit real secrets.

# Admin panel login password
VITE_ADMIN_PASSWORD=your_password_here

# GitHub personal access token (classic, repo scope)
# Generate at: https://github.com/settings/tokens
# Expires — regenerate and update here + Vercel dashboard when it does
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub repo details — where content is committed
VITE_GITHUB_OWNER=your_github_username
VITE_GITHUB_REPO=your_repo_name
VITE_GITHUB_BRANCH=main

# Vercel deploy hook — triggers a manual build from the Deploy button in admin
# Create at: Vercel project → Settings → Git → Deploy Hooks
VITE_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxx/yyy

# Local file mode
# true  → admin saves write directly to local disk (no GitHub API, no commits)
# false → admin saves commit to GitHub (production behaviour)
# Set to true in .env.local for local dev, leave false/unset on Vercel
VITE_USE_LOCAL_FILES=false
